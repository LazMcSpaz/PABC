VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. If set, the editor shows a PIN gate before loading the tool.
# Leave unset for local dev. The PIN is bundled into the JS at build
# time (Vite's VITE_* vars are public), so this is a "don't show this
# tab to anyone over my shoulder" gate, not real security.
VITE_EDITOR_PIN=
