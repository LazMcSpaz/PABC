VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. If set, the editor shows a PIN gate before loading the tool.
# Leave unset for local dev. The PIN is bundled into the JS at build
# time (Vite's VITE_* vars are public), so this is a "don't show this
# tab to anyone over my shoulder" gate, not real security.
VITE_EDITOR_PIN=

# Optional. If all three are set, every successful save / import in the
# editor auto-commits a generated content snapshot to the configured
# branch. See editor/README.md for token scoping. Like the PIN, the
# token ends up in the JS bundle — gated by the PIN, but use a
# fine-grained PAT scoped to this one repo with contents: write only.
VITE_GITHUB_TOKEN=
VITE_GITHUB_REPO=LazMcSpaz/PABC
VITE_GITHUB_CONTENT_BRANCH=content/auto-snapshot
VITE_GITHUB_BASE_BRANCH=main
